{
    "_common": {
        "description": "Common settings shared across all presets",
        "env": {
            "CINETIC_ROOT": "__CWD__",
            "CINETIC_WRAPPERS_PATH": "__CWD__/wrappers"
        },
        "sbatch": [],
        "header": [],
        "topology": ""
    },
    "leonardo": {
        "description": "Leonardo Cluster @ CINECA",
        "env": {
            "CINETIC_WL_MANAGER": "slurm",
            "CINETIC_PINNING_FLAGS": "--cpu-bind=socket",
            "LD_LIBRARY_PATH": "${LD_LIBRARY_PATH}:/leonardo/smcx_home/bench/software/lib/ucx/nvhpc-22.2_pgi_cuda/lib/",
            "UCX_IB_SL": "1",
            "UCX_LOG_LEVEL": "error",
            "NCCL_IB_SL": "${NCCL_IB_SL}"
        },
        "sbatch": [
            "--account=IscrB_SWING",
            "--partition=boost_usr_prod",
            "--gres=tmpfs:0"
        ],
        "header": [
            "module purge",
            "module load openmpi"
        ]
    },
    "local": {
        "description": "Local Development Environment (OpenMPI)",
        "env": {
            "CINETIC_WL_MANAGER": "mpi",
            "CINETIC_MPIRUN": "mpirun",
            "CINETIC_MPIRUN_MAP_BY_NODE_FLAG": "--map-by node",
            "CINETIC_MPIRUN_HOSTNAMES_FLAG": "-H",
            "CINETIC_MPIRUN_ADDITIONAL_FLAGS": "--mca orte_tmpdir_base /tmp",
            "CINETIC_PINNING_FLAGS": ""
        },
        "sbatch": [],
        "header": [],
        "topology": "topologies/example.json"
    },
    "example_preset": {
        "description": "Example Template",
        "env": {
            "CINETIC_ROOT": "__CWD__",
            "ENV_EXAMPLE": "ENV_VALUE"
        },
        "sbatch": [],
        "header": [],
        "topology": "topologies/example.json"
    }
}
